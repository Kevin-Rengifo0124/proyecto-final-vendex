<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/vendex_bg_dark"
    tools:context=".Vendedor.Productos.AgregarProductoActivity">

    <!-- Header con imagen incluida (igual que las demás vistas) -->
    <LinearLayout
        android:id="@+id/toolbarRL"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_header_registro"
        android:orientation="vertical"
        android:gravity="center"
        android:paddingTop="32dp"
        android:paddingBottom="28dp"
        android:layout_marginBottom="0dp">

        <TextView
            android:text="@string/txtAgregarProductos"
            android:textColor="@color/colorBlanco"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <androidx.appcompat.widget.AppCompatImageView
            android:id="@+id/imgAgregarProducto"
            android:layout_marginTop="10dp"
            android:layout_marginBottom="10dp"
            android:src="@drawable/agregar_producto"
            android:layout_width="80dp"
            android:layout_height="80dp"/>

    </LinearLayout>

    <!-- Contenido scrollable -->
    <androidx.core.widget.NestedScrollView
        android:id="@+id/scrollContent"
        android:layout_below="@id/toolbarRL"
        android:layout_above="@id/botonAgregarProducto"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="15dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Grid de imágenes seleccionadas -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/RV_ImagenesProducto"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                app:spanCount="4"
                app:layoutManager="androidx.recyclerview.widget.GridLayoutManager"
                tools:listitem="@layout/item_imagen_seleccionadas" />

            <!-- Nombre del producto -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/TIL_NombreProducto"
                style="@style/InputOutlined"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp">

                <EditText
                    android:id="@+id/editNombreProducto"
                    android:hint="@string/editNombreProducto"
                    android:inputType="textCapSentences"
                    android:textColor="@color/colorBlanco"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"/>

            </com.google.android.material.textfield.TextInputLayout>

            <!-- Descripción del producto -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/TIL_DescripcionProducto"
                style="@style/InputOutlined"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp">

                <EditText
                    android:id="@+id/editDescripcionProducto"
                    android:hint="@string/editDescripcionProducto"
                    android:inputType="textCapSentences"
                    android:textColor="@color/colorBlanco"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"/>

            </com.google.android.material.textfield.TextInputLayout>

            <!-- Precio del producto -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/TIL_Precio"
                style="@style/InputOutlined"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp">

                <EditText
                    android:id="@+id/editPrecioProducto"
                    android:hint="@string/editPrecioProducto"
                    android:inputType="numberDecimal"
                    android:textColor="@color/colorBlanco"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"/>

            </com.google.android.material.textfield.TextInputLayout>

            <!-- Switch de descuento -->
            <androidx.appcompat.widget.SwitchCompat
                android:id="@+id/descuentoSwitch"
                android:text="@string/txtDescuento"
                android:textColor="@color/colorBlanco"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:layout_marginBottom="4dp"
                android:paddingStart="4dp"/>

            <!-- Precio con descuento -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/TIL_PrecioDescuento"
                style="@style/InputOutlined"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp">

                <EditText
                    android:id="@+id/editPrecioConDescuentoProducto"
                    android:hint="@string/editPrecioConDescuentoProducto"
                    android:inputType="numberDecimal"
                    android:textColor="@color/colorBlanco"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"/>

            </com.google.android.material.textfield.TextInputLayout>

            <!-- Nota del descuento -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/TIL_NotaDescuento"
                style="@style/InputOutlined"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:layout_marginBottom="8dp">

                <EditText
                    android:id="@+id/editNotaDescuentoProducto"
                    android:hint="@string/editNotaDescuentoProducto"
                    android:inputType="textCapSentences"
                    android:textColor="@color/colorBlanco"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"/>

            </com.google.android.material.textfield.TextInputLayout>

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

    <!-- Botón agregar producto -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/botonAgregarProducto"
        android:text="@string/botonAgregarProducto"
        android:layout_alignParentBottom="true"
        android:textAllCaps="true"
        android:layout_margin="10dp"
        app:backgroundTint="@color/vendex_blue_primary"
        app:cornerRadius="12dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"/>

</RelativeLayout>